# Chave da API do Google Gemini — pegue em https://aistudio.google.com/apikey
# NUNCA coloque essa chave no código do navegador (HTML/JS do front-end).
# Ela deve existir SOMENTE aqui, no servidor.
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Supabase — pegue em: painel do projeto → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Porta em que o servidor vai rodar
PORT=3000

# Origem permitida para chamadas (seu domínio do front-end).
# Em desenvolvimento local pode deixar * ou http://localhost:5500
ALLOWED_ORIGIN=*
