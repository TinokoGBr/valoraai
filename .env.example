# Chave da API do Google Gemini — pegue em https://aistudio.google.com/apikey
# NUNCA coloque essa chave no código do navegador (HTML/JS do front-end).
# Ela deve existir SOMENTE aqui, no servidor.
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Porta em que o servidor vai rodar
PORT=3000

# Origem permitida para chamadas (seu domínio do front-end).
# Em desenvolvimento local pode deixar * ou http://localhost:5500 (ajuste pra sua porta do front)
ALLOWED_ORIGIN=*
